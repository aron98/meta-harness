{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@meta-harness/core": ["packages/core/src/index.ts"],
      "@meta-harness/fixtures": ["packages/fixtures/src/index.ts"],
      "@meta-harness/plugin": ["packages/plugin/src/index.ts"]
    },
    "types": ["node", "vitest/globals"]
  }
}
