{
  "name": "@meta-harness/cli",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "meta-harness": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --dir ../.. --filter @meta-harness/core build && pnpm --dir ../.. --filter @meta-harness/fixtures build && tsup --config tsup.config.ts",
    "test": "pnpm --dir ../.. exec vitest run apps/cli/test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@meta-harness/core": "workspace:*",
    "@meta-harness/fixtures": "workspace:*"
  }
}
