    "directory": "packages/plugins/opencode-meta-harness"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "pnpm --dir ../../.. exec vitest run packages/plugins/opencode-meta-harness/test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@meta-harness/core": "workspace:*",
    "@meta-harness/plugin-core": "workspace:*",
    "zod": "^3.24.4"
  }
